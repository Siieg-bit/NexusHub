# =============================================================================
# NexusHub — Variáveis de Ambiente do Backend (Template)
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# O arquivo .env NUNCA deve ser commitado no Git.
#
# Secrets das Edge Functions devem ser configurados via painel:
#   https://supabase.com/dashboard > Edge Functions > Secrets
# =============================================================================

# --- Supabase ---
# Obtenha em: https://supabase.com/dashboard > Settings > API Keys
# NOVO FORMATO (Mar/2026+): Publishable Key substitui a Anon Key
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_SUA_PUBLISHABLE_KEY_AQUI
SUPABASE_SERVICE_ROLE_KEY=sb_secret_SUA_SECRET_KEY_AQUI

# --- Database ---
# Obtenha em: https://supabase.com/dashboard > Settings > Database
SUPABASE_DB_PASSWORD=SUA_SENHA_DO_BANCO_AQUI

# =============================================================================
# Edge Function Secrets (configurar no painel ou via: supabase secrets set)
# =============================================================================

# --- Agora RTC (Chamadas de Voz/Vídeo) ---
# Obtenha em: https://console.agora.io > Project Management
AGORA_APP_ID=SEU_AGORA_APP_ID_AQUI
AGORA_APP_CERTIFICATE=SEU_AGORA_APP_CERTIFICATE_AQUI

# --- Webhook HMAC ---
# Gere com: openssl rand -hex 32
# Configure no painel do RevenueCat/Stripe como webhook secret
WEBHOOK_SECRET=GERE_COM_openssl_rand_-hex_32

# --- Firebase Cloud Messaging (Push Notifications) ---
# Obtenha em: https://console.firebase.google.com > Project Settings > Service Accounts
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"SEU_PROJETO",...}
