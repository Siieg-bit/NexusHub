# =============================================================================
# NexusHub — Variáveis de Ambiente do Frontend (Template)
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# O arquivo .env NUNCA deve ser commitado no Git.
#
# Como usar:
#   cp .env.example .env
#   # Edite o .env com suas credenciais
# =============================================================================

# --- Supabase ---
# Obtenha em: https://supabase.com/dashboard > Settings > API Keys
# NOVO FORMATO (a partir de Mar/2026): use a Publishable Key no lugar da Anon Key
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_SUA_PUBLISHABLE_KEY_AQUI

# --- Agora RTC (Chamadas de Voz/Vídeo) ---
# Obtenha em: https://console.agora.io > Project Management
# ATENÇÃO: Nunca coloque o App Certificate aqui — ele fica apenas nos Edge Function Secrets do Supabase
AGORA_APP_ID=SEU_AGORA_APP_ID_AQUI

# --- RevenueCat (In-App Purchases) ---
# Obtenha em: https://app.revenuecat.com > Projects > API Keys
REVENUECAT_KEY_ANDROID=SUA_REVENUECAT_KEY_ANDROID_AQUI

# --- AdMob ---
# Obtenha em: https://admob.google.com > Apps > App Settings
ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_REWARDED_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# --- Giphy ---
# Obtenha em: https://developers.giphy.com > Dashboard > Create App
GIPHY_API_KEY=SUA_GIPHY_API_KEY_AQUI
